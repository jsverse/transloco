{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": "../../dist/out-tsc",
    "sourceMap": false,
    "declaration": false,
    "lib": ["es2022"],
    "module": "preserve",
    "target": "ES2021",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler"
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
