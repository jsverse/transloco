{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": "../../dist/out-tsc",
    "sourceMap": false,
    "declaration": false,
    "lib": ["es2022"],
    "module": "commonjs",
    "target": "ES2021",
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts", "jest.config.js", "src/test-setup.ts"]
}
